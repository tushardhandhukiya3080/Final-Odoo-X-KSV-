# --- Database (matches docker-compose ports) ---
# Postgres runs on host port 5544 to avoid clashing with your other containers.
DATABASE_URL=postgresql://appuser:apppassword@localhost:5544/appdb

# --- Auth ---
# CHANGE THIS in production. Min 16 chars. Generate: openssl rand -base64 32
JWT_SECRET=dev-only-change-me-to-a-long-random-secret-0000

# --- App ---
NODE_ENV=development

# --- n8n automation bridge ---
N8N_WEBHOOK_URL=http://localhost:5688/webhook

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Google OAuth (Login with Google) ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
# (use your deployed origin in production). Leave blank to hide the button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Fixed public origin for the OAuth redirect (recommended behind a proxy so a
# spoofed Host header can't alter it). Optional locally — falls back to the
# request origin. No trailing slash, e.g. https://rideshare.example.com
APP_URL=

# --- Payments (Razorpay Test Mode) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Maps (OpenStreetMap / OSRM / Nominatim — no API key required) ---
OSRM_URL=https://router.project-osrm.org
NOMINATIM_URL=https://nominatim.openstreetmap.org
