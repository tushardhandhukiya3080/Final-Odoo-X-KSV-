# --- Database (matches docker-compose ports) ---
# Postgres runs on host port 5544 to avoid clashing with your other containers.
DATABASE_URL=postgresql://appuser:apppassword@localhost:5544/appdb

# --- Auth ---
# CHANGE THIS in production. Min 16 chars. Generate: openssl rand -base64 32
JWT_SECRET=dev-only-change-me-to-a-long-random-secret-0000

# --- App ---
NODE_ENV=development

# --- n8n automation bridge ---
N8N_WEBHOOK_URL=http://localhost:5688/webhook

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Google OAuth (Login with Google) ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
# (use your deployed origin in production). Leave blank to hide the button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Fixed public origin for the OAuth redirect (recommended behind a proxy so a
# spoofed Host header can't alter it). Optional locally — falls back to the
# request origin. No trailing slash, e.g. https://rideshare.example.com
APP_URL=

# --- Payments (Razorpay Test Mode) ---
# dashboard.razorpay.com -> switch to Test Mode -> Settings -> API Keys -> Generate.
# Set these two and wallet recharge + trip UPI/Card open the real Razorpay popup.
# Leave both blank to fall back to a mock order (auto-completes, no popup).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional — the client key id. Falls back to RAZORPAY_KEY_ID if left blank
# (the key id is public, so this just needs to equal RAZORPAY_KEY_ID).
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Maps (OpenStreetMap / OSRM / Nominatim — no API key required) ---
OSRM_URL=https://router.project-osrm.org
NOMINATIM_URL=https://nominatim.openstreetmap.org

# --- Vehicle RC / RTO verification ---
# Set ONE provider below and the "Verify with RTO" button returns real
# owner/model/insurance from VAHAN. Leave both blank to fall back to the local
# plate-format + duplicate check. Cashfree wins if both are set.

# Option A — RapidAPI (recommended: no business KYC, free tier). Subscribe to any
# "RTO Vehicle Information" API on RapidAPI, open its Code Snippets tab, and copy:
#   RAPIDAPI_RTO_KEY   = your X-RapidAPI-Key
#   RAPIDAPI_RTO_HOST  = the X-RapidAPI-Host value (e.g. rto-vehicle-information-verification-india.p.rapidapi.com)
#   RAPIDAPI_RTO_URL   = the endpoint URL. Put {plate} where the number goes, e.g.
#                        https://<host>/getVehicleInfo?vehicle_no={plate}
#                        OR leave the query off and set RAPIDAPI_RTO_PARAM instead.
#   RAPIDAPI_RTO_METHOD= GET or POST (default GET)
#   RAPIDAPI_RTO_PARAM = the plate param name if not using {plate} (default vehicleNumber)
#   RAPIDAPI_RTO_BODY  = full POST body JSON with a {plate} placeholder, for APIs that
#                        need extra fields, e.g. consent:
#                        {"vehicle_no":"{plate}","consent":"Y","consent_text":"…"}
RAPIDAPI_RTO_KEY=
RAPIDAPI_RTO_HOST=
RAPIDAPI_RTO_URL=
RAPIDAPI_RTO_METHOD=GET
RAPIDAPI_RTO_PARAM=vehicleNumber
RAPIDAPI_RTO_BODY=

# Option B — Cashfree Vehicle-RC (needs business KYC + approval).
CASHFREE_RC_BASE=https://sandbox.cashfree.com/verification
CASHFREE_RC_CLIENT_ID=
CASHFREE_RC_CLIENT_SECRET=
