# --- Database (matches docker-compose ports) ---
# Postgres runs on host port 5544 to avoid clashing with your other containers.
DATABASE_URL=postgresql://appuser:apppassword@localhost:5544/appdb

# --- Auth ---
# CHANGE THIS in production. Min 16 chars. Generate: openssl rand -base64 32
JWT_SECRET=dev-only-change-me-to-a-long-random-secret-0000

# --- App ---
NODE_ENV=development

# --- n8n automation bridge ---
N8N_WEBHOOK_URL=http://localhost:5688/webhook

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Payments (Razorpay Test Mode) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Maps (OpenStreetMap / OSRM / Nominatim — no API key required) ---
OSRM_URL=https://router.project-osrm.org
NOMINATIM_URL=https://nominatim.openstreetmap.org
